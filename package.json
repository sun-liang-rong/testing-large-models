{
  "name": "model-authenticity-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Vue 3 + NestJS web console for probing OpenAI-compatible model relay endpoints for suspected model substitution.",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "ts-node --transpile-only src/main.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "npm run build:api && npm run build:web",
    "build:api": "tsc -p tsconfig.build.json",
    "build:web": "vite build",
    "start": "node dist/main.js",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/**/*.spec.js",
    "typecheck": "vue-tsc --noEmit"
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-express": "^10.4.20",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "node-fetch": "^2.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.1",
    "@types/node-fetch": "^2.6.13",
    "@vitejs/plugin-vue": "^4.6.2",
    "autoprefixer": "^10.5.1",
    "concurrently": "^8.2.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^4.5.3",
    "vue-tsc": "^2.2.12"
  }
}
