{
  "name": "model-authenticity-lab",
  "version": "0.1.0",
  "private": true,
  "description": "React + NestJS web console for probing OpenAI-compatible model relay endpoints for suspected model substitution.",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "ts-node --transpile-only src/main.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "npm run build:api && npm run build:web",
    "build:api": "tsc -p tsconfig.build.json",
    "build:web": "vite build",
    "start": "node dist/main.js",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/**/*.spec.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-express": "^10.4.20",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "node-fetch": "^2.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node-fetch": "^2.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^4.5.3"
  }
}
